---
import Base from '../../layouts/Base.astro';
import { loadMatches, getMatchById, getMatchStats, getMatchTimeline, getMatchLive } from '../../lib/data.js';
import MatchHero from '../../components/match/MatchHero.svelte';
import ShotMap from '../../components/match/ShotMap.svelte';
import GoalMap from '../../components/match/GoalMap.svelte';
import EventTimeline from '../../components/match/EventTimeline.svelte';

export function getStaticPaths() {
  const matches = loadMatches();
  return matches.map((m: any) => ({
    params: { id: m.id },
  }));
}

const { id } = Astro.params;
const match = getMatchById(id);

if (!match) {
  return Astro.redirect('/');
}

const matchStats = getMatchStats(id);
const timeline = getMatchTimeline(id);
const liveData = getMatchLive(id);
---

<Base title={`${match.homeTeam} vs ${match.awayTeam} - FIFA 2026`}>
  <div class="match-page">
    <a href={import.meta.env.BASE_URL} class="back-link">← Back to Dashboard</a>

    <MatchHero match={match} liveData={liveData} client:load />

    <div class="visualizations">
      <section class="viz-section viz-full-width">
        <h2>Shots</h2>
        <ShotMap matchStats={matchStats} timeline={timeline} homeTeam={match.homeTeam} awayTeam={match.awayTeam} homeScore={match.homeScore} awayScore={match.awayScore} liveData={liveData} client:load />
      </section>

      <section class="viz-section viz-full-width">
        <h2>Shots on Goal</h2>
        <GoalMap timeline={timeline} liveData={liveData} homeTeam={match.homeTeam} awayTeam={match.awayTeam} client:load />
      </section>

      <section class="viz-section viz-full-width">
        <h2>Match Events</h2>
        <EventTimeline timeline={timeline} homeTeam={match.homeTeam} awayTeam={match.awayTeam} liveData={liveData} client:load />
      </section>
    </div>
  </div>
</Base>

<style>
  .match-page {
    margin-bottom: var(--space-3xl);
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-lg);
    color: var(--color-home);
    text-decoration: none;
    font-size: 0.875rem;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    opacity: 0.8;
  }

  .visualizations {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
    gap: var(--space-2xl);
  }

  .viz-section {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-lg);
  }

  .viz-section.viz-full-width {
    grid-column: 1 / -1;
  }

  .viz-section h2 {
    margin-top: 0;
    margin-bottom: var(--space-lg);
    font-size: 1.125rem;
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    .visualizations {
      grid-template-columns: 1fr;
    }
  }
</style>
