---
import Base from '../../layouts/Base.astro';
import { loadMatches, getMatchById, getMatchStats, getMatchTimeline, getMatchLive, getMatchPlayerStats } from '../../lib/data.js';
import TeamStatsComparison from '../../components/match/TeamStatsComparison.svelte';
import EventTimeline from '../../components/match/EventTimeline.svelte';
import PlayerHighlights from '../../components/match/PlayerHighlights.svelte';
import ShotMap from '../../components/match/ShotMap.svelte';

export function getStaticPaths() {
  const matches = loadMatches();
  return matches.map((m: any) => ({
    params: { id: m.id },
  }));
}

const { id } = Astro.params;
const match = getMatchById(id);

if (!match) {
  return Astro.redirect('/');
}

const matchStats = getMatchStats(id);
const timeline = getMatchTimeline(id);
const liveData = getMatchLive(id);
const playerStats = getMatchPlayerStats(id);
---

<Base title={`${match.homeTeam} vs ${match.awayTeam} - FIFA 2026`}>
  <div class="match-header">
    <a href="/" class="back-link">← Back to Dashboard</a>

    <div class="match-info">
      <div class="team">
        <div class="team-name">{match.homeTeam}</div>
        <div class="team-logo">{match.homeTeam.slice(0, 3).toUpperCase()}</div>
      </div>

      <div class="score-section">
        <div class="score">
          {match.homeScore !== null ? match.homeScore : '-'}
          <span class="score-separator">-</span>
          {match.awayScore !== null ? match.awayScore : '-'}
        </div>
        <div class="match-meta">
          <div>{match.stage}</div>
          <div>{match.group}</div>
          <div>{new Date(match.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
        </div>
      </div>

      <div class="team">
        <div class="team-logo">{match.awayTeam.slice(0, 3).toUpperCase()}</div>
        <div class="team-name">{match.awayTeam}</div>
      </div>
    </div>
  </div>

  <div class="visualizations">
    <section class="viz-section">
      <h2>Team Statistics</h2>
      <TeamStatsComparison matchStats={matchStats} homeTeam={match.homeTeam} awayTeam={match.awayTeam} client:load />
    </section>

    <section class="viz-section">
      <h2>Shot Map</h2>
      <ShotMap matchStats={matchStats} homeTeam={match.homeTeam} awayTeam={match.awayTeam} client:load />
    </section>

    <section class="viz-section">
      <h2>Match Events</h2>
      <EventTimeline timeline={timeline} homeTeam={match.homeTeam} awayTeam={match.awayTeam} liveData={liveData} client:load />
    </section>

    <section class="viz-section">
      <h2>Top Performers</h2>
      <PlayerHighlights playerStats={playerStats} homeTeam={match.homeTeam} awayTeam={match.awayTeam} client:load />
    </section>
  </div>
</Base>

<style>
  .match-header {
    margin-bottom: var(--space-3xl);
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-lg);
    color: var(--color-home);
    text-decoration: none;
    font-size: 0.875rem;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    opacity: 0.8;
  }

  .match-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    padding: var(--space-xl);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .team {
    flex: 1;
    text-align: center;
  }

  .team-name {
    font: var(--font-display-sm);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .team-logo {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-home);
    color: white;
    border-radius: 50%;
    font-weight: 700;
    font-size: 1.5rem;
    margin: 0 auto;
  }

  .score-section {
    flex: 0.8;
    text-align: center;
  }

  .score {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1;
    margin-bottom: var(--space-md);
  }

  .score-separator {
    display: inline-block;
    margin: 0 var(--space-sm);
  }

  .match-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
  }

  .visualizations {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
    gap: var(--space-2xl);
  }

  .viz-section {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-lg);
  }

  .viz-section h2 {
    margin-top: 0;
    margin-bottom: var(--space-lg);
    font-size: 1.125rem;
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    .match-info {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .team-logo {
      width: 60px;
      height: 60px;
      font-size: 1.25rem;
    }

    .score {
      font-size: 2.5rem;
    }

    .visualizations {
      grid-template-columns: 1fr;
    }
  }
</style>
