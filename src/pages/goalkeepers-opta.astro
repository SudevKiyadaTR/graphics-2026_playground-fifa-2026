---
import Base from '../layouts/Base.astro';
import GoalkeeperTableOpta from '../components/GoalkeeperTableOpta.svelte';
import { loadGoalkeeperStatsOpta } from '../lib/data.js';

const gks = loadGoalkeeperStatsOpta();
const withSaves = gks.filter((g) => g.saves > 0);

// Minimum shots faced to qualify for save%-ranked views (small samples skew the rate).
const MIN_SHOTS = 5;

// Summary cards
const totalSaves = gks.reduce((s, g) => s + g.saves, 0);
const totalGKs = gks.length;
const mostSaves = gks[0]; // already sorted by saves desc
const bestSavePct = [...gks]
  .filter((g) => g.shotsFaced >= MIN_SHOTS && g.savePct != null)
  .sort((a, b) => b.savePct - a.savePct)[0];
const mostCleanSheets = [...gks].sort((a, b) => b.cleanSheets - a.cleanSheets)[0];
const mostGoalKicks = [...gks].sort((a, b) => b.goalKicks - a.goalKicks)[0];

// Shared bar geometry
const BAR_W = 600;
const BAR_H = 28;
const BAR_GAP = 6;
const LABEL_W = 160;
const NUM_W = 40;
const VIEW_W = LABEL_W + BAR_W + NUM_W + 16;

// Saves leaderboard (top 15)
const savesGks = withSaves.slice(0, 15);
const maxSaves = savesGks[0]?.saves || 1;

// Clean sheets leaderboard (top 15 with ≥1)
const cleanGks = [...gks]
  .filter((g) => g.cleanSheets > 0)
  .sort((a, b) => b.cleanSheets - a.cleanSheets || b.appearances - a.appearances)
  .slice(0, 15);
const maxClean = cleanGks[0]?.cleanSheets || 1;

// Pass accuracy (top 15 with a meaningful sample)
const passGks = [...gks]
  .filter((g) => g.passes >= 30 && g.passPct != null)
  .sort((a, b) => b.passPct - a.passPct)
  .slice(0, 15);

// Scatter: save% vs shots faced (≥ MIN_SHOTS)
const scatterGks = gks.filter((g) => g.shotsFaced >= MIN_SHOTS && g.savePct != null);
const SC_W = 520;
const SC_H = 320;
const SC_PAD = { top: 20, right: 20, bottom: 40, left: 48 };
const scInnerW = SC_W - SC_PAD.left - SC_PAD.right;
const scInnerH = SC_H - SC_PAD.top - SC_PAD.bottom;
const maxScShots = Math.max(...scatterGks.map((g) => g.shotsFaced), 1);
const scX = (shots: number) => (shots / maxScShots) * scInnerW;
const scY = (pct: number) => scInnerH - pct * scInnerH;
---

<Base title="Goalkeepers (Opta) — FIFA 2026 Dashboard">
  <div class="page-header">
    <h1>Goalkeepers <span class="src-badge">Opta</span></h1>
    <p>{totalGKs} goalkeepers · {totalSaves} total saves · sourced from the Opta match feed</p>
  </div>

  <!-- Summary cards -->
  <div class="cards">
    <div class="card">
      <span class="card-value">{totalSaves}</span>
      <span class="card-label">Total Saves</span>
      <span class="card-desc">All shots stopped by goalkeepers across every match in the tournament.</span>
    </div>
    {mostSaves && (
      <div class="card">
        <span class="card-value">{mostSaves.saves}</span>
        <span class="card-label">Most Saves</span>
        <span class="card-sub">{mostSaves.playerName} · {mostSaves.teamName}</span>
        <span class="card-desc">Goalkeeper with the highest raw save count in the tournament.</span>
      </div>
    )}
    {bestSavePct && (
      <div class="card">
        <span class="card-value">{(bestSavePct.savePct * 100).toFixed(1)}%</span>
        <span class="card-label">Best Save% (≥{MIN_SHOTS} faced)</span>
        <span class="card-sub">{bestSavePct.playerName} · {bestSavePct.teamName}</span>
        <span class="card-desc">Saves divided by shots faced (saves + goals conceded). Minimum {MIN_SHOTS} shots faced to qualify.</span>
      </div>
    )}
    {mostCleanSheets && mostCleanSheets.cleanSheets > 0 && (
      <div class="card">
        <span class="card-value">{mostCleanSheets.cleanSheets}</span>
        <span class="card-label">Most Clean Sheets</span>
        <span class="card-sub">{mostCleanSheets.playerName} · {mostCleanSheets.teamName}</span>
        <span class="card-desc">Matches finished without conceding — the mark of a settled defence.</span>
      </div>
    )}
    {mostGoalKicks && (
      <div class="card">
        <span class="card-value">{mostGoalKicks.goalKicks}</span>
        <span class="card-label">Most Goal Kicks</span>
        <span class="card-sub">{mostGoalKicks.playerName} · {mostGoalKicks.teamName}</span>
        <span class="card-desc">Goal kicks taken — a proxy for how often a keeper restarted play from the back.</span>
      </div>
    )}
  </div>

  <!-- Charts row -->
  <div class="charts-row">

    <!-- Saves leaderboard -->
    <section class="chart-section">
      <h2 class="section-title">Saves Leaderboard</h2>
      <p class="section-desc">Top 15 goalkeepers by total saves made. The more saves, the busier the keeper — though a high count can reflect a team under pressure as much as individual quality.</p>
      <div class="chart-wrap">
        <svg width="100%" viewBox={`0 0 ${VIEW_W} ${savesGks.length * (BAR_H + BAR_GAP)}`} class="chart-svg">
          {savesGks.map((gk, i) => {
            const y = i * (BAR_H + BAR_GAP);
            const barLen = (gk.saves / maxSaves) * BAR_W;
            const isBest = i === 0;
            return (
              <>
                <text x={LABEL_W - 8} y={y + BAR_H / 2 + 5} text-anchor="end" class={`bar-label ${isBest ? 'bar-label--best' : ''}`}>
                  {gk.playerName.length > 20 ? gk.playerName.slice(0, 19) + '…' : gk.playerName}
                </text>
                <rect x={LABEL_W} y={y} width={barLen} height={BAR_H} rx="3" class={`bar-rect ${isBest ? 'bar-rect--best' : ''}`} />
                <text x={LABEL_W + barLen + 6} y={y + BAR_H / 2 + 5} class="bar-value">{gk.saves}</text>
              </>
            );
          })}
        </svg>
      </div>
    </section>

    <!-- Save% vs shots faced scatter -->
    <section class="chart-section">
      <h2 class="section-title">Save% vs Shots Faced (≥{MIN_SHOTS})</h2>
      <p class="section-desc">Each dot is a goalkeeper. Right = more shots faced, up = better save rate. The best keepers sit top-right: high volume and high efficiency. Hover a dot for details.</p>
      <div class="chart-wrap">
        <svg width="100%" viewBox={`0 0 ${SC_W} ${SC_H}`} class="chart-svg">
          <g transform={`translate(${SC_PAD.left},${SC_PAD.top})`}>
            {[0, 0.25, 0.5, 0.75, 1.0].map((pct) => (
              <>
                <line x1={0} y1={scY(pct)} x2={scInnerW} y2={scY(pct)} stroke="var(--color-border)" stroke-width="1" />
                <text x={-6} y={scY(pct) + 4} text-anchor="end" class="axis-label">{(pct * 100).toFixed(0)}%</text>
              </>
            ))}
            {[0, Math.round(maxScShots / 4), Math.round(maxScShots / 2), Math.round(maxScShots * 3 / 4), maxScShots].map((v) => (
              <text x={scX(v)} y={scInnerH + 24} text-anchor="middle" class="axis-label">{v}</text>
            ))}
            <text x={scInnerW / 2} y={scInnerH + 38} text-anchor="middle" class="axis-title">Shots faced</text>
            {scatterGks.map((gk) => (
              <g class="scatter-dot-group">
                <circle cx={scX(gk.shotsFaced)} cy={scY(gk.savePct)} r="5" class="scatter-dot" />
                <title>{gk.playerName} ({gk.teamName}) — {gk.saves} saves / {gk.shotsFaced} faced, {(gk.savePct * 100).toFixed(1)}% save rate</title>
              </g>
            ))}
            {scatterGks
              .filter((g) => g.shotsFaced >= 15 || g.savePct >= 0.85)
              .map((gk) => (
                <text x={scX(gk.shotsFaced) + 7} y={scY(gk.savePct) + 4} class="scatter-label">
                  {gk.playerName.split(' ').pop()}
                </text>
              ))}
          </g>
        </svg>
      </div>
    </section>
  </div>

  <!-- Clean sheets leaderboard -->
  {cleanGks.length > 0 && (
    <section class="chart-section chart-section--full">
      <h2 class="section-title">Clean Sheets</h2>
      <p class="section-desc">Matches a goalkeeper finished without conceding. As much a measure of the defence in front of them as of the keeper — but the shutouts still land on their record.</p>
      <div class="chart-wrap">
        <svg width="100%" viewBox={`0 0 ${VIEW_W} ${cleanGks.length * (BAR_H + BAR_GAP)}`} class="chart-svg">
          {cleanGks.map((gk, i) => {
            const y = i * (BAR_H + BAR_GAP);
            const barLen = (gk.cleanSheets / maxClean) * BAR_W;
            const isBest = i === 0;
            return (
              <>
                <text x={LABEL_W - 8} y={y + BAR_H / 2 + 5} text-anchor="end" class={`bar-label ${isBest ? 'bar-label--best' : ''}`}>
                  {gk.playerName.length > 20 ? gk.playerName.slice(0, 19) + '…' : gk.playerName}
                </text>
                <rect x={LABEL_W} y={y} width={barLen} height={BAR_H} rx="3" class="bar-rect bar-rect--clean" />
                <text x={LABEL_W + barLen + 6} y={y + BAR_H / 2 + 5} class="bar-value">{gk.cleanSheets} / {gk.appearances}</text>
              </>
            );
          })}
        </svg>
      </div>
    </section>
  )}

  <!-- Pass accuracy -->
  {passGks.length > 0 && (
    <section class="chart-section chart-section--full">
      <h2 class="section-title">Distribution Accuracy (≥30 passes)</h2>
      <p class="section-desc">Share of a keeper's passes that found a teammate. High accuracy points to a short, controlled build-up; lower rates often mean a keeper going long and gambling on second balls.</p>
      <div class="chart-wrap">
        <svg width="100%" viewBox={`0 0 ${VIEW_W} ${passGks.length * (BAR_H + BAR_GAP)}`} class="chart-svg">
          {passGks.map((gk, i) => {
            const y = i * (BAR_H + BAR_GAP);
            const barLen = gk.passPct * BAR_W;
            return (
              <>
                <text x={LABEL_W - 8} y={y + BAR_H / 2 + 5} text-anchor="end" class="bar-label">
                  {gk.playerName.length > 20 ? gk.playerName.slice(0, 19) + '…' : gk.playerName}
                </text>
                <rect x={LABEL_W} y={y} width={BAR_W} height={BAR_H} rx="3" class="bar-bg" />
                <rect x={LABEL_W} y={y} width={barLen} height={BAR_H} rx="3" class="bar-rect bar-rect--dist" />
                <text x={LABEL_W + barLen + 6} y={y + BAR_H / 2 + 5} class="bar-value">{(gk.passPct * 100).toFixed(1)}%</text>
              </>
            );
          })}
        </svg>
      </div>
    </section>
  )}

  <!-- Full sortable table -->
  <section>
    <h2 class="section-title">All Goalkeeper Stats</h2>
    <p class="section-sub">Click any column header to sort</p>
    <GoalkeeperTableOpta goalkeepers={gks} client:load />
  </section>

  <p class="footnote">
    Data sourced from the Opta match feed and aggregated across all played matches.
    Save% = saves ÷ (saves + goals conceded). The source feed omits goals conceded for
    some matches, so save% is approximate — it reads slightly high for keepers whose
    matches are missing that field.
  </p>
</Base>

<style>
  .page-header {
    margin-bottom: var(--space-xl);
  }
  .page-header p {
    font: var(--font-body-lg);
    color: var(--color-text-secondary);
  }
  .src-badge {
    font-size: 0.9rem;
    font-weight: 600;
    vertical-align: middle;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    margin-left: var(--space-sm);
  }

  .cards {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    min-width: 160px;
    flex: 1;
  }
  .card-value {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text-primary);
  }
  .card-label {
    font: var(--font-label);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.7rem;
  }
  .card-sub {
    font: var(--font-body-sm);
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }
  .card-desc {
    font: var(--font-body-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    line-height: 1.45;
  }

  .charts-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
  }
  @media (max-width: 900px) {
    .charts-row {
      grid-template-columns: 1fr;
    }
  }

  .chart-section {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-lg);
    margin-bottom: var(--space-xl);
  }
  .chart-section--full {
    width: 100%;
  }

  .section-title {
    font: var(--font-display-sm);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-md) 0;
  }
  .section-sub {
    font: var(--font-body-sm);
    color: var(--color-text-secondary);
    margin: calc(-1 * var(--space-sm)) 0 var(--space-md);
  }
  .section-desc {
    font: var(--font-body-sm);
    color: var(--color-text-muted);
    margin: calc(-1 * var(--space-xs)) 0 var(--space-md);
    line-height: 1.5;
  }

  .chart-wrap {
    overflow-x: auto;
  }
  .chart-svg {
    display: block;
  }
  .footnote {
    font: var(--font-body-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-lg);
    max-width: 60ch;
    line-height: 1.5;
  }
</style>

<style is:global>
  /* SVG styles must be global to reach SVG elements */
  .bar-label {
    font-size: 12px;
    fill: var(--color-text-secondary);
  }
  .bar-label--best {
    fill: var(--color-text-primary);
    font-weight: 600;
  }
  .bar-rect {
    fill: #253144;
  }
  .bar-rect--best {
    fill: #4fb3e8;
  }
  .bar-rect--dist {
    fill: #2bb56a;
  }
  .bar-rect--clean {
    fill: #7c5cce;
  }
  .bar-bg {
    fill: #1a2535;
  }
  .bar-value {
    font-size: 12px;
    fill: var(--color-text-secondary);
    font-variant-numeric: tabular-nums;
  }
  .axis-label {
    font-size: 11px;
    fill: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .axis-title {
    font-size: 11px;
    fill: var(--color-text-secondary);
  }
  .scatter-dot {
    fill: #4fb3e8;
    opacity: 0.75;
    transition: opacity 0.15s;
  }
  .scatter-dot-group:hover .scatter-dot {
    opacity: 1;
    r: 7;
  }
  .scatter-label {
    font-size: 10px;
    fill: var(--color-text-secondary);
  }
</style>
