---
import Base from '../layouts/Base.astro';
import FixturesTable from '../components/FixturesTable.svelte';
import { loadMatches } from '../lib/data.js';

const matches = loadMatches() as any[];

const allFixtures = matches.sort((a: any, b: any) => new Date(a.date).getTime() - new Date(b.date).getTime());

// Calculate tournament stats
const played = matches.filter(m => m.homeScore !== null && m.awayScore !== null);
const upcoming = matches.filter(m => m.homeScore === null || m.awayScore === null);
const totalGoals = matches.reduce((sum, m) => sum + (m.homeScore || 0) + (m.awayScore || 0), 0);
const avgGoalsPerMatch = played.length > 0 ? (totalGoals / played.length).toFixed(2) : '0';
const maxGoalsInMatch = Math.max(...matches.map(m => (m.homeScore || 0) + (m.awayScore || 0)));
const draws = played.filter(m => m.homeScore === m.awayScore).length;
---

<Base title="FIFA 2026 Dashboard">
  <div class="hero">
    <h1>FIFA World Cup 2026</h1>
    <p>Tournament dashboard with live standings, match results, and player statistics.</p>
  </div>

  <section class="stats-grid">
    <div class="stat-card">
      <div class="stat-card__value">{played.length}</div>
      <div class="stat-card__label">Matches Played</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__value">{upcoming.length}</div>
      <div class="stat-card__label">Matches Remaining</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__value">{totalGoals}</div>
      <div class="stat-card__label">Total Goals</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__value">{avgGoalsPerMatch}</div>
      <div class="stat-card__label">Goals Per Match</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__value">{draws}</div>
      <div class="stat-card__label">Draws</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__value">{maxGoalsInMatch}</div>
      <div class="stat-card__label">Most Goals in Match</div>
    </div>
  </section>

  {allFixtures.length > 0 && (
    <section class="fixtures-section">
      <h2>Fixtures</h2>
      <FixturesTable data={allFixtures} base={import.meta.env.BASE_URL} client:load />
    </section>
  )}

  <section class="info-section">
    <h2>Tournament Structure</h2>
    <p>
      The 2026 FIFA World Cup features 48 teams divided into 16 groups of 3. Each team plays two
      matches in the group stage. The top two teams from each group advance to the Round of 16.
    </p>
  </section>
</Base>

<style>
  .hero {
    margin-bottom: var(--space-2xl);
    text-align: center;
  }

  .hero h1 {
    margin-bottom: var(--space-md);
  }

  .hero p {
    font: var(--font-body-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .stat-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: var(--space-lg);
    text-align: center;
  }

  .stat-card__value {
    font: var(--font-display-lg);
    color: var(--color-text-primary);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .stat-card__label {
    font: var(--font-label);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    margin-top: var(--space-sm);
  }

  .info-section {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: var(--space-lg);
    margin-top: var(--space-2xl);
  }

  .info-section h2 {
    margin-top: 0;
  }

  .info-section p {
    color: var(--color-text-secondary);
  }

  .fixtures-section {
    margin-top: var(--space-2xl);
  }

  .fixtures-section h2 {
    margin-bottom: var(--space-lg);
  }
</style>
