---
import Base from '../layouts/Base.astro';
import PlayerStatsTable from '../components/PlayerStatsTable.svelte';
import { loadTeamStatsOpta } from '../lib/data.js';

const consolidatedRows = loadTeamStatsOpta();

const FIXED_KEYS = new Set(['teamName', 'teamCode', 'matchCount']);
const statKeys = consolidatedRows.length > 0
  ? Object.keys(consolidatedRows[0]).filter((k) => !FIXED_KEYS.has(k))
  : [];

const DEFAULT_STATS = [
  'goals', 'goalsConceded', 'goalDifference', 'goalAssist',
  'totalScoringAtt', 'ontargetScoringAtt', 'totalPass', 'accuratePass',
  'totalTackle', 'wonTackle', 'fouls', 'wasFouled', 'yellowCard', 'redCard',
];
---

<Base title="Teams (Opta) — FIFA 2026 Dashboard">
  <div class="page-header">
    <h1>Teams — Opta</h1>
    <p>{consolidatedRows.length} teams · {statKeys.length} stat columns · Opta source</p>
  </div>

  <PlayerStatsTable
    consolidatedRows={consolidatedRows}
    statKeys={statKeys}
    defaultStats={DEFAULT_STATS}
    entityKey="teamName"
    entityHeader="Team"
    showTeamColumn={false}
    searchPlaceholder="Team..."
    csvPrefix="team-stats-opta"
    consolidatedTabLabel="By Team"
    client:load
  />
</Base>

<style>
  .page-header {
    margin-bottom: var(--space-lg);
  }

  .page-header p {
    font: var(--font-mono);
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
  }
</style>
